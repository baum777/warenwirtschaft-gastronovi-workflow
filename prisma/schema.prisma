generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SyncRun {
  id           String        @id @default(cuid())
  source       String
  status       SyncRunStatus
  startedAt    DateTime      @default(now())
  finishedAt   DateTime?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  rawPayloads RawPayload[]
}

model RawPayload {
  id          String   @id @default(cuid())
  source      String
  externalId  String?
  entityType  String?
  payloadHash String   @unique
  payloadJson Json
  syncRunId   String?
  syncRun     SyncRun? @relation(fields: [syncRunId], references: [id])
  receivedAt  DateTime @default(now())

  @@index([source, externalId])
  @@index([payloadHash])
  @@index([syncRunId])
}

model WorkflowEvent {
  id             String    @id @default(cuid())
  type           String
  version        Int
  source         String
  externalId     String?
  idempotencyKey String    @unique
  businessDate   DateTime?
  occurredAt     DateTime
  importedAt     DateTime  @default(now())
  payloadRef     String?
  dataJson       Json
  metadataJson   Json?
  createdAt      DateTime  @default(now())

  tasks WorkflowTask[]

  @@index([type, occurredAt])
  @@index([source, externalId])
  @@index([businessDate])
}

model WorkflowTask {
  id              String             @id @default(cuid())
  type            String
  status          WorkflowTaskStatus
  severity        String
  title           String
  description     String?
  workflowEventId String?
  workflowEvent   WorkflowEvent?     @relation(fields: [workflowEventId], references: [id])
  assignedRole    String?
  createdAt       DateTime           @default(now())
  resolvedAt      DateTime?

  @@index([workflowEventId])
}

model UserProfile {
  id                         String   @id @default(cuid())
  authUserId                 String   @unique @db.Uuid
  email                      String   @unique
  displayName                String?
  avatarUrl                  String?
  defaultTeamId              String?
  preferredStorageLocationId String?
  preferencesJson            Json?
  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  defaultTeam Team?        @relation("DefaultTeam", fields: [defaultTeamId], references: [id])
  memberships TeamMember[]
  sentInvites TeamInvite[] @relation("InviteSender")

  @@index([defaultTeamId])
  @@index([preferredStorageLocationId])
}

model Team {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  defaultLocationId  String?
  createdByProfileId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  defaultForProfiles UserProfile[] @relation("DefaultTeam")
  defaultLocation    StorageLocation? @relation("TeamDefaultLocation", fields: [defaultLocationId], references: [id])
  members            TeamMember[]
  invites            TeamInvite[]

  @@index([slug])
  @@index([defaultLocationId])
  @@index([createdByProfileId])
}

model TeamMember {
  id        String           @id @default(cuid())
  teamId    String
  profileId String
  role      TeamRole
  status    TeamMemberStatus @default(active)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  team    Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  profile UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([teamId, profileId])
  @@index([profileId])
  @@index([teamId, role])
  @@index([teamId, status])
}

model TeamInvite {
  id                 String           @id @default(cuid())
  teamId             String
  email              String
  role               TeamRole
  tokenHash          String           @unique
  status             TeamMemberStatus @default(invited)
  invitedByProfileId String
  expiresAt          DateTime
  acceptedAt         DateTime?
  revokedAt          DateTime?
  createdAt          DateTime         @default(now())

  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy UserProfile @relation("InviteSender", fields: [invitedByProfileId], references: [id])

  @@index([teamId])
  @@index([email])
  @@index([status, expiresAt])
}

model InventoryItem {
  id                String           @id @default(cuid())
  name              String
  sku               String?
  category          String?
  defaultUnit       String
  minStock          Float?
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  movements          InventoryMovement[]
  orderItems         PurchaseOrderItem[]
  receiptItems       GoodsReceiptItem[]
  stockSnapshots     InventoryStockSnapshot[]
  correctionRequests InventoryCorrectionRequest[]

  @@index([name])
  @@index([category])
  @@index([storageLocationId])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model StorageLocation {
  id        String   @id @default(cuid())
  name      String
  type      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryItems InventoryItem[]
  receiptItems   GoodsReceiptItem[]
  movements      InventoryMovement[]
  stockSnapshots InventoryStockSnapshot[]
  defaultForTeams Team[] @relation("TeamDefaultLocation")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String?
  supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  status      PurchaseOrderStatus @default(draft)
  createdById String
  orderedAt   DateTime?
  note        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items     PurchaseOrderItem[]
  receipts  GoodsReceipt[]
  movements InventoryMovement[]

  @@index([status])
  @@index([createdAt])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  orderedQty      Float
  receivedQty     Float         @default(0)
  unit            String
  note            String?

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model GoodsReceipt {
  id              String         @id @default(cuid())
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  receivedById    String
  receivedAt      DateTime       @default(now())
  note            String?
  createdAt       DateTime       @default(now())

  items     GoodsReceiptItem[]
  movements InventoryMovement[]

  @@index([purchaseOrderId])
  @@index([receivedAt])
}

model GoodsReceiptItem {
  id                String           @id @default(cuid())
  goodsReceiptId    String
  goodsReceipt      GoodsReceipt     @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  inventoryItemId   String
  inventoryItem     InventoryItem    @relation(fields: [inventoryItemId], references: [id])
  quantity          Float
  unit              String
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  note              String?

  @@index([goodsReceiptId])
  @@index([inventoryItemId])
  @@index([storageLocationId])
}

model InventoryMovement {
  id                String                @id @default(cuid())
  inventoryItemId   String
  inventoryItem     InventoryItem         @relation(fields: [inventoryItemId], references: [id])
  type              InventoryMovementType
  quantity          Float
  unit              String
  actorUserId       String
  storageLocationId String?
  storageLocation   StorageLocation?      @relation(fields: [storageLocationId], references: [id])
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  goodsReceiptId    String?
  goodsReceipt      GoodsReceipt?         @relation(fields: [goodsReceiptId], references: [id])
  relatedMovementId String?
  note              String?
  createdAt         DateTime              @default(now())

  @@index([inventoryItemId, createdAt])
  @@index([type])
  @@index([actorUserId])
  @@index([storageLocationId])
  @@index([purchaseOrderId])
  @@index([goodsReceiptId])
}

model InventoryStockSnapshot {
  id                String           @id @default(cuid())
  inventoryItemId   String
  inventoryItem     InventoryItem    @relation(fields: [inventoryItemId], references: [id])
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  quantity          Float
  unit              String
  calculatedAt      DateTime         @default(now())

  @@unique([inventoryItemId, storageLocationId])
  @@index([storageLocationId])
  @@index([calculatedAt])
}

model InventoryCorrectionRequest {
  id                String                    @id @default(cuid())
  inventoryItemId   String
  inventoryItem     InventoryItem             @relation(fields: [inventoryItemId], references: [id])
  requestedById     String
  status            InventoryCorrectionStatus @default(open)
  expectedDelta     Float
  unit              String
  reason            String
  relatedMovementId String?
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime                  @default(now())

  @@index([status])
  @@index([inventoryItemId])
}

enum SyncRunStatus {
  running
  succeeded
  failed
  partially_failed
}

enum WorkflowTaskStatus {
  open
  in_review
  resolved
  dismissed
}

enum TeamRole {
  admin
  shift_lead
  staff
}

enum TeamMemberStatus {
  invited
  active
  suspended
}

enum PurchaseOrderStatus {
  draft
  ordered
  partially_received
  received
  cancelled
}

enum InventoryMovementType {
  goods_received
  item_removed
  correction_positive
  correction_negative
}

enum InventoryCorrectionStatus {
  open
  approved
  rejected
}
